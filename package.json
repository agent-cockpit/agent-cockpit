{
  "name": "agent-cockpit",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "test": "vitest",
    "test:watch": "vitest",
    "build": "pnpm --filter @cockpit/ui exec vite build",
    "typecheck": "tsc --noEmit",
    "sync-map": "pnpm exec tsx scripts/sync-map.ts",
    "copy-faces": "cd packages/ui && pnpm exec tsx ../../scripts/copy-faces.ts"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vitest": "^3.0.0",
    "tsx": "latest"
  }
}
